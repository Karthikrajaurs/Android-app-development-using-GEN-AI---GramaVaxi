<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/CardStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Animal Photo/Icon -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAnimalPhoto"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_sheep"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            tools:src="@drawable/ic_sheep"/>

        <!-- Animal Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/tvAnimalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Lakshmi"/>

            <TextView
                android:id="@+id/tvAnimalType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                tools:text="Sheep • Bannur"/>

            <TextView
                android:id="@+id/tvAnimalAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp"
                tools:text="Age: 24 months"/>

            <TextView
                android:id="@+id/tvNextVaccination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/warning"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                tools:text="Next: FMD on 15 May"
                tools:visibility="visible"/>

        </LinearLayout>

        <!-- Status Indicator -->
        <ImageView
            android:id="@+id/ivStatusIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_notification"
            app:tint="@color/success"
            android:contentDescription="Status"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>